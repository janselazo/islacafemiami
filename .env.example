# Public site URL (optional — defaults to https://islacafemiami.com)
NEXT_PUBLIC_SITE_URL=https://islacafemiami.com

# Instagram Graph API — required for the homepage 4×4 feed at build time
# See docs/INSTAGRAM_SETUP.md for how to generate these values.
#
# INSTAGRAM_ACCESS_TOKEN — Page access token (not a short-lived user token)
# INSTAGRAM_USER_ID      — Instagram Business Account ID (numeric)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Google Places API (New) — required for live Google reviews at build time
# See docs/GOOGLE_REVIEWS_SETUP.md for Place ID and API key setup.
#
# GOOGLE_PLACES_API_KEY — API key with Places API (New) enabled
# GOOGLE_PLACE_ID       — Business Place ID (e.g. ChIJ...); optional on first build
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# WhatsApp click-to-chat — public number shown on the floating button
# E.164 digits only (US example: 13055550147 for (305) 555-0147)
# See docs/WHATSAPP_SETUP.md
NEXT_PUBLIC_WHATSAPP_NUMBER=13055550147

# Online ordering links (header/footer Order menu)
# NEXT_PUBLIC_ORDER_UBER_EATS_URL=
# NEXT_PUBLIC_ORDER_TOAST_URL=
# NEXT_PUBLIC_ORDER_DOORDASH_URL=
# NEXT_PUBLIC_ORDER_GRUBHUB_URL=

# Set all secrets in Cloudflare Pages → Settings → Environment variables (Production)
# For local testing, copy this file to .env.local and fill in the values.
